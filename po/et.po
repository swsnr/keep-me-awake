#. Translators: Do feel free to translate the application name
#: de.swsnr.keepmeawake.desktop:3 de.swsnr.keepmeawake.metainfo.xml:5
#: src/keep_me_awake/resources/application-window.blp:10
msgid "Keep me Awake"
msgstr "Hoia mind ärkvel"

#: de.swsnr.keepmeawake.desktop:4
msgid "Keep your desktop awake"
msgstr "Ära lase töölaual unne vajuda"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: de.swsnr.keepmeawake.desktop:10
msgid "GNOME;GTK;Suspend;Idle;Inhibit;"
msgstr "GNOME;GTK;Suspend;Idle;Inhibit;jõude;unumine;tukastama;tukasta;keela;luba;"

#: de.swsnr.keepmeawake.metainfo.xml:6
msgid "Inhibit lock screen and suspend"
msgstr "Keela lukustusvaade ja unerežiim"

#: de.swsnr.keepmeawake.metainfo.xml:8
msgid ""
"Inhibit lock screen and suspend of your desktop system, via the main user "
"interface or via global shortcuts."
msgstr ""
"Keela oma süle- või lauaarvuti lukustusvaade ja unerežiim kas "
"kasutajaliidesest või üldiste kiirklahvidega."

#: de.swsnr.keepmeawake.metainfo.xml:14
msgid "Suspend"
msgstr "Unerežiim"

#: de.swsnr.keepmeawake.metainfo.xml:15
msgid "Inhibit"
msgstr "Keela"

#: de.swsnr.keepmeawake.metainfo.xml:16
msgid "Idle"
msgstr "Jõude"

#: de.swsnr.keepmeawake.metainfo.xml:30
msgid "Rewrite in Python."
msgstr "Rakenduse uus iteratsioon, mis on kirjutatud Pythonis."

#: de.swsnr.keepmeawake.metainfo.xml:31
msgid "Drop support for global shortcuts."
msgstr "Üldiste kiirklahvide tugi pole enam saadaval."

#: de.swsnr.keepmeawake.metainfo.xml:32
msgid "Add command line flag to inhibit."
msgstr "Lisandus keelamiseks kasutatav käsureavõti."

#: de.swsnr.keepmeawake.metainfo.xml:42
msgid "Add global Super+W shortcut to toggle inhibiting sleep."
msgstr "Lisasime üldise Super+W kiirklahv unerežiimi keelamiseks/lubamiseks."

#: de.swsnr.keepmeawake.metainfo.xml:43
msgid "Once started keep running in background to react to global shortcuts."
msgstr ""
"Peale käivitamist jääb rakendus taustal tööle ja saab reageerida üldiste "
"kiirklahvide vajutustele."

#: de.swsnr.keepmeawake.metainfo.xml:44
msgid ""
"Add menu items to show application shortcuts and, in supported desktop "
"environments, configure global shortcuts."
msgstr ""
"Lisasime menüüvaliku kiirklahvide jaoks ja kui töölauakeskkond seda toetab, "
"ka võimaluse üldiste kiirklahvide seadistamiseks."

#: de.swsnr.keepmeawake.metainfo.xml:45
msgid "Inhibit suspend and session lock on startup."
msgstr "Lukustusvaate ja unerežiimi keelamise võimalus käivitamisel."

#: de.swsnr.keepmeawake.metainfo.xml:46 de.swsnr.keepmeawake.metainfo.xml:66
#: de.swsnr.keepmeawake.metainfo.xml:72
msgid "Update translations."
msgstr "Uuendatud tõlked."

#: de.swsnr.keepmeawake.metainfo.xml:59
msgid "Update to GNOME 49."
msgstr "Uuendus kasutab nüüd GNOME 49 teeke."

#: de.swsnr.keepmeawake.metainfo.xml:60 de.swsnr.keepmeawake.metainfo.xml:80
#: de.swsnr.keepmeawake.metainfo.xml:87 de.swsnr.keepmeawake.metainfo.xml:95
msgid "Global shortcuts are not yet supported."
msgstr "Üldised kiirklahvid pole veel toetatud."

#: de.swsnr.keepmeawake.metainfo.xml:78
msgid "Do not show redundant notification when quitting."
msgstr "Väljumisel ei kuva enam mittevajalikku teavitust."

#: de.swsnr.keepmeawake.metainfo.xml:79
msgid "Show indicator if app was updated in background."
msgstr ""
"Kui rakendust uuendatakse taustal, siis näitame graafilist indikaatorit."

#: de.swsnr.keepmeawake.metainfo.xml:86
msgid "Keep inhibiting screen lock even after the main window is closed."
msgstr "Lukustusvaate keelamine jätkub ka peale põhiakna sulgemist."

#: de.swsnr.keepmeawake.metainfo.xml:93
msgid "Add persistent notification when sleep or screen lock are inhibited."
msgstr "Kui lukustusvaade ja unerežiim on keelatud, siis kuvame püsiteavitust."

#: de.swsnr.keepmeawake.metainfo.xml:94
msgid "Correctly quit the app."
msgstr "Rakenduse sulgemine toimib nüüd korrektselt."

#: de.swsnr.keepmeawake.metainfo.xml:105
msgid ""
"Add main window with toggles to inhibit either suspend, or suspend and "
"screen lock."
msgstr ""
"Lisandus nuppudega põhivaade, kus saab keelata lukustusvaade ja unerežiimi "
"või need käivitada."

#: de.swsnr.keepmeawake.metainfo.xml:106
msgid "Global shortcuts and notifications are not yet supported."
msgstr "Üldised kiirklahvid ja teavitused pole veel toetatud."

#: de.swsnr.keepmeawake.metainfo.xml:118
msgid "Inhibit nothing"
msgstr "Vaade, mis näitab, et mitte midagi pole keelatud"

#: de.swsnr.keepmeawake.metainfo.xml:122
msgid "Inhibit suspend and screen locking"
msgstr "Lukustusvaade ja unerežiim on keelatud"

#: src/keep_me_awake/app.py:99
msgctxt "option description"
msgid "Toggle inhibition"
msgstr "Lülita keelamine sisse/välja"

#: src/keep_me_awake/app.py:109
msgctxt "notification.title"
msgid "Suspend and screen lock inhibited"
msgstr "Lukustusvaade ja unerežiim on keelatud"

#: src/keep_me_awake/app.py:113
msgctxt "notification.body"
msgid "Keep me Awake inhibits suspend and screen lock at your request."
msgstr ""
"Rakendus „Hoia mind ärkvel“ on sinu palvel keelanud arvuti unerežiimi ja "
"lukustusvaate."

#: src/keep_me_awake/app.py:118
msgctxt "notification.title"
msgid "Suspend inhibited"
msgstr "Unerežiim on keelatud"

#: src/keep_me_awake/app.py:122
msgctxt "notification.body"
msgid "Keep me Awake inhibits suspend at your request."
msgstr "Rakendus „Hoia mind ärkvel“ on sinu palvel keelanud arvuti unerežiimi."

